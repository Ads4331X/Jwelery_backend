// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  DELIVERY_STAFF
}

enum MetalType {
  GOLD
  SILVER
  DIAMOND
  PLATINUM
  OTHER
}

enum MakingChargeType {
  FIXED // flat NPR amount
  PERCENTAGE // % of metal value
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD // Cash on Delivery
  ESEWA
  KHALTI
  BANK_TRANSFER
}

enum EnquiryStatus {
  UNREAD
  READ
  REPLIED
}

enum OtpPurpose {
  PASSWORD_RESET
  SIGNUP_VERIFICATION
}

// Which table an OTP code belongs to — lets one OtpCode model serve
// both customer (User) and Admin password resets.
enum OtpAccountType {
  CUSTOMER
  ADMIN
}

// ─────────────────────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────────────────────

model Admin {
  id          String    @id @default(cuid())
  username    String?
  email       String    @unique
  password    String
  role        AdminRole @default(ADMIN)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("admins")
}

// ─────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  email         String    @unique
  password      String
  firstName     String?
  lastName      String?
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  addresses Address[]
  orders    Order[]
  cart      Cart?
  wishlist  Wishlist?
  reviews   Review[]

  @@map("users")
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  fullName   String
  phone      String
  street     String
  city       String
  state      String?
  postalCode String?
  country    String  @default("Nepal")
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  parentId    String? // self-relation for sub-categories
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────
// METAL RATES  (admin publishes daily gold / silver rate)
// ─────────────────────────────────────────────────────────────

model MetalRate {
  id          String    @id @default(cuid())
  metalType   MetalType
  ratePerGram Decimal   @db.Decimal(10, 2) // NPR per gram
  updatedBy   String? // Admin id who published this rate
  createdAt   DateTime  @default(now())

  @@index([metalType, createdAt])
  @@map("metal_rates")
}

// ─────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────

// Computed price formula (done in Express.js at runtime):
//   metalCost     = currentRatePerGram × weightGrams
//   wastageAmt    = metalCost × (wastagePercent / 100)
//   makingAmt     = FIXED  → makingCharge
//                   PERCENT → metalCost × (makingCharge / 100)
//   subtotal      = metalCost + wastageAmt + makingAmt
//   vatAmt        = subtotal × (vatPercent / 100)   ← default 13 %
//   FINAL PRICE   = subtotal + vatAmt

model Product {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  description      String?          @db.Text
  categoryId       String
  metalType        MetalType
  weightGrams      Decimal          @db.Decimal(8, 3) // grams
  purity           String? // "24K" | "22K" | "92.5%" etc.
  makingCharge     Decimal          @db.Decimal(10, 2)
  makingChargeType MakingChargeType @default(FIXED)
  wastagePercent   Decimal          @default(0) @db.Decimal(5, 2)
  vatPercent       Decimal          @default(13) @db.Decimal(5, 2) // Nepal VAT
  stock            Int              @default(0)
  isFeatured       Boolean          @default(false)
  isDealOfDay      Boolean          @default(false)
  isActive         Boolean          @default(true)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([categoryId])
  @@index([metalType])
  @@index([isFeatured])
  @@index([isDealOfDay])
  @@index([isActive])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ─────────────────────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId]) // no duplicate products in cart
  @@index([cartId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String @id @default(cuid())
  wishlistId String
  productId  String

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([wishlistId, productId]) // no duplicate products in wishlist
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique // human-readable: AJ-2026-0001
  userId        String
  addressId     String?
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod @default(COD)
  paymentRef    String? // eSewa / Khalti transaction ID

  // ── Price breakdown snapshot at time of order ──
  metalCost     Decimal @db.Decimal(12, 2)
  makingCharge  Decimal @db.Decimal(12, 2)
  wastageCharge Decimal @default(0) @db.Decimal(12, 2)
  vatAmount     Decimal @db.Decimal(12, 2)
  totalAmount   Decimal @db.Decimal(12, 2)

  // Metal rate used at checkout (stored so price doesn't drift)
  metalRateSnapshot Json? // { GOLD: 9500.00, SILVER: 120.00 }

  notes       String?   @db.Text
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user       User             @relation(fields: [userId], references: [id])
  address    Address?         @relation(fields: [addressId], references: [id])
  items      OrderItem[]
  statusLogs OrderStatusLog[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  productId     String
  // ── Snapshots so order history is accurate even if product changes ──
  productName   String
  metalType     MetalType
  weightGrams   Decimal   @db.Decimal(8, 3)
  metalRate     Decimal   @db.Decimal(10, 2) // NPR/gram at time of order
  makingCharge  Decimal   @db.Decimal(10, 2)
  wastageCharge Decimal   @default(0) @db.Decimal(10, 2)
  vatPercent    Decimal   @db.Decimal(5, 2)
  unitPrice     Decimal   @db.Decimal(12, 2) // final computed price per unit
  quantity      Int
  totalPrice    Decimal   @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// Tracks every status change for delivery staff + admin audit trail
model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedBy String? // Admin id
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_logs")
}

// ─────────────────────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int // 1 – 5
  comment   String?  @db.Text
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId]) // one review per product per user
  @@index([productId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────
// BANNERS  (homepage slider / promotions)
// ─────────────────────────────────────────────────────────────

model Banner {
  id        String    @id @default(cuid())
  title     String?
  imageUrl  String
  linkUrl   String? // optional CTA link
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("banners")
}

// ─────────────────────────────────────────────────────────────
// CONTACT / ENQUIRIES
// ─────────────────────────────────────────────────────────────

model ContactEnquiry {
  id        String        @id @default(cuid())
  fullName  String
  email     String?
  phone     String?
  message   String        @db.Text
  status    EnquiryStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@map("contact_enquiries")
}

// ─────────────────────────────────────────────────────────────
// OTP  (email codes for password reset / signup verification)
// ─────────────────────────────────────────────────────────────

model OtpCode {
  id          String         @id @default(cuid())
  accountId   String // User.id or Admin.id, depending on accountType
  accountType OtpAccountType @default(CUSTOMER)
  codeHash    String // bcrypt hash of the 6-digit code — never store plaintext
  purpose     OtpPurpose     @default(PASSWORD_RESET)
  expiresAt   DateTime
  consumed    Boolean        @default(false) // set true after successful /verify
  resetUsedAt DateTime? // set true exactly once during successful /reset
  attempts    Int            @default(0) // failed verify attempts against this code
  createdAt   DateTime       @default(now())

  // No FK relation here on purpose — accountId can point at either the
  // users or admins table depending on accountType, and Prisma doesn't
  // support polymorphic relations. Cleanup of stale rows is handled by
  // expiresAt + a periodic cleanup job, not cascading deletes.
  @@index([accountId, accountType, purpose, consumed])
  @@map("otp_codes")
}

// ─────────────────────────────────────────────────────────────
// SITE SETTINGS  (key-value — admin edits without code changes)
// ─────────────────────────────────────────────────────────────

// Example keys:
//   store_name, store_phone, store_email, store_address,
//   whatsapp_number, facebook_url, instagram_url,
//   default_vat_percent, google_maps_embed_url

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
